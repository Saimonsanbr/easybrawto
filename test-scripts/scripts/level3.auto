chrome.persistProfile('teste')

functions testarReact {
  .navigate('http://127.0.0.1:5500/testes-exemplos/level3.html')
  .waitLoad()
  .waitSeconds(3)
  .clickIfExists('Aceitar cookies')
  .waitSeconds(3)
  .waitFor('#produtos')
  .waitSeconds(2)
  .scroll('down', 500)
  .waitSeconds(2)
  .insertText('busca', 'câmera')
  .waitSeconds(2)
  .scroll('bottom')
  .waitSeconds(3)
  .clickIfExists('Agora não')
  .waitSeconds(2)
  .waitFor('#contato')
  .waitSeconds(2)
  .insertText('nome', 'Pedro Alves')
  .waitSeconds(2)
  .insertText('email', 'pedro@email.com')
  .waitSeconds(2)
  .selectOption('assunto', 'Reclamação')
  .waitSeconds(2)
  .insertText('mensagem', 'React não me parou!')
  .waitSeconds(2)
  .checkBox('aceitar-termos')
  .waitSeconds(2)
  .clickButton('Enviar mensagem')
  .waitSeconds(2)
  .waitForText('Mensagem enviada')
  .screenshot('site3-ok.png')
  .log('React vencido!')
}

run testarReact