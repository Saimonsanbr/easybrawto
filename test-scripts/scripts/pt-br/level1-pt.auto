navegador.manterPerfil('teste')

funcoes preencherFormulario {
  .navegar('http://localhost:8080/test-scripts/level1.html')
  .esperarCarregar()
  .esperarSegundos(3)
  .clicarSeExistir('Aceitar cookies')
  .rolar('down', 400)
  .esperarSegundos(2)
  .inserirTexto('busca', 'teclado')
  .clicarBotao('Buscar')
  .esperarSegundos(2)
  .rolar('bottom')
  .esperarSegundos(2)
  .clicarSeExistir('Agora não')
  .esperarSegundos(2)
  .inserirTexto('nome', 'João Silva')
  .inserirTexto('email', 'joao@email.com')
  .selecionarOpcao('assunto', 'Dúvida')
  .inserirTexto('mensagem', 'Testando em português!')
  .marcarCaixa('aceitar-termos')
  .clicarBotao('Enviar mensagem')
  .esperarTexto('Mensagem enviada com sucesso')
  .capturarTela('site1-pt.png')
  .imprimir('Funcionou em português!')
}

rodar preencherFormulario